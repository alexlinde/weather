# Mobile app environment (Expo public vars are inlined at build time)

# Unified backend base URL (serves /api/weather/*, /api/radar/*, and the web export).
# Dev: the FastAPI server on port 8000. Prod: your deployed domain.
EXPO_PUBLIC_API_URL=http://localhost:8000

# Default PWS station id
EXPO_PUBLIC_DEFAULT_STATION=KCATRUCK306

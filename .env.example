# ─────────────────────────────────────────────────────────────────────────────
# Weather monorepo — backend environment
# Copy to .env and fill in. The mobile app reads EXPO_PUBLIC_* from apps/mobile/.env
# ─────────────────────────────────────────────────────────────────────────────

# Weather Company / Weather Underground API key (required for /api/weather/*)
WU_API_KEY=

# Default PWS station id for current observations / history
WU_DEFAULT_STATION=KCATRUCK306

# Optional: raster basemap tile API key for richer base map styles
# MapTiler — https://www.maptiler.com  (used by the radar basemap)
MAPTILER_API_KEY=

# Stadia Maps — https://stadiamaps.com
STADIA_API_KEY=

# If both are empty, the radar basemap falls back to OpenFreeMap raster (no key needed)

# GCP service account key for deploy.sh (avoids interactive gcloud auth login)
# GCP_SA_KEY=.gcp-key.json

# Data cache directory (default: ./data relative to project root)
# DATA_DIR=/tmp/data

# Skip S3 seeding and warm from disk cache (local dev)
# DEV_MODE=1

# In-memory tilt cache entries (default: 30, ~39 MB each)
# TILT_CACHE_SIZE=30

# In-memory tile cache entries (default: 2000)
# TILE_CACHE_SIZE=2000

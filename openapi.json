    "/api/radar/motion-raw/{timestamp}.bin": {
      "get": {
        "summary": "Radar Motion Tile Raw",
        "description": "Serve the motion field as raw RGB bytes (for native DataTexture upload).\n\nDecodes the stored motion PNG server-side so React Native doesn't need a PNG\ndecoder. Width/height are returned in the X-Width / X-Height headers.",
        "operationId": "radar_motion_tile_raw_api_radar_motion_raw__timestamp__bin_get",
        "parameters": [
          {
            "name": "timestamp",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",

    "/api/radar/atlas/{timestamp}/{z}/{x}/{y}.png": {
      "get": {
        "summary": "Radar Atlas Tile",
        "description": "Serve a 256\u00d72048 grayscale PNG atlas tile with 8 tilt bands.",
